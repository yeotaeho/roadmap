# 이 파일을 복사해 `local.env` 로 저장한 뒤 값을 채우세요. `local.env` 는 Git 에 커밋하지 않습니다.
#
# Flutter compile-time (Android/iOS 필수):
#   flutter run --dart-define-from-file=dart_defines/local.env
#   VS Code/Cursor: .vscode/launch.json 또는 scripts/dev.ps1
#
# Android Gradle 은 같은 파일에서 카카오/네이버 네이티브 키만 주입합니다.

API_BASE_URL=http://localhost:8000

KAKAO_NATIVE_APP_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CLIENT_NAME=청년 인사이트

# Google 네이티브 로그인 — serverClientId 는 Web OAuth Client ID (GOOGLE_CLIENT_ID 와 동일)
GOOGLE_SERVER_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
